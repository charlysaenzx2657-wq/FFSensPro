<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ff_black"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Settings button top right -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="@string/btn_settings"
            android:textSize="18sp"
            android:padding="0dp"
            app:backgroundTint="@color/ff_dark_card"
            app:cornerRadius="22dp"
            app:strokeColor="@color/ff_orange"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

        <!-- Header -->
        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/header_title"
            android:textColor="@color/ff_orange"
            android:textSize="26sp"
            android:fontFamily="@font/orbitron_bold"
            android:letterSpacing="0.12"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSettings" />

        <TextView
            android:id="@+id/tvSubHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/header_subtitle"
            android:textColor="@color/ff_gray"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Device Info Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDeviceInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="invisible"
            app:cardBackgroundColor="@color/ff_dark_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_device"
                        app:tint="@color/ff_orange" />

                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Escaneando..."
                        android:textColor="@color/ff_white"
                        android:textSize="16sp"
                        android:fontFamily="@font/orbitron_bold"
                        android:layout_marginStart="10dp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ff_divider"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvDeviceDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Leyendo specs..."
                    android:textColor="@color/ff_gray"
                    android:textSize="12sp"
                    android:lineSpacingExtra="4dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFfStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/ff_checking"
                    android:textColor="@color/ff_white"
                    android:textSize="11sp"
                    app:chipBackgroundColor="@color/ff_dark_card"
                    app:chipStrokeColor="@color/ff_orange"
                    app:chipStrokeWidth="1dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Scan button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:text="@string/btn_scan"
            android:textColor="@color/ff_black"
            android:textSize="13sp"
            android:fontFamily="@font/orbitron_bold"
            android:letterSpacing="0.05"
            app:backgroundTint="@color/ff_orange"
            app:cornerRadius="30dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/cardDeviceInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/progressScan"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:visibility="gone"
            android:progressTint="@color/ff_orange"
            android:progressBackgroundTint="@color/ff_dark_card"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnScan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvScanStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/scanning"
            android:textColor="@color/ff_orange_dim"
            android:textSize="12sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/progressScan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/footer_note"
            android:textColor="@color/ff_gray_dim"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvScanStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
