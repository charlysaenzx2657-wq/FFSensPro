<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ff_black"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btnBackSettings"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_back"
        android:background="@drawable/bg_icon_btn"
        app:tint="@color/ff_orange"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textColor="@color/ff_orange"
        android:textSize="22sp"
        android:fontFamily="@font/orbitron_bold"
        android:gravity="center"
        android:paddingTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBackSettings"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardSettings"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/ff_dark_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle"
        app:layout_constraintBottom_toTopOf="@id/btnSaveLang"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_language"
                android:textColor="@color/ff_orange"
                android:textSize="14sp"
                android:fontFamily="@font/orbitron_bold"
                android:paddingBottom="12dp" />

            <ListView
                android:id="@+id/listLanguages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@color/ff_divider"
                android:dividerHeight="1dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveLang"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/settings_save"
        android:textColor="@color/ff_black"
        android:textSize="14sp"
        android:fontFamily="@font/orbitron_bold"
        app:backgroundTint="@color/ff_orange"
        app:cornerRadius="28dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
